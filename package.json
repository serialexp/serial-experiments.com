{
  "name": "@serialexp/serial-experiments-com",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "serial-experiments.com — SolidJS SSR + SQLite, served by Bun.",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build && vite build --ssr src/entry-server.tsx",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.tsx",
    "start": "bun run server.ts",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.16.1",
    "isomorphic-dompurify": "^2.16.0",
    "marked": "^14.1.4",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@aeolun/solid-jsx-oxc": "0.1.0-alpha.16",
    "@aeolun/vite-plugin-solid-oxc": "0.1.0-alpha.16",
    "@types/node": "^22.9.0",
    "bun-types": "^1.1.34",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
