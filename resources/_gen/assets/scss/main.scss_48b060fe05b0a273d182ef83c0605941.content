body,html{margin:0;padding:0}*{box-sizing:border-box}body{background-color:#221d1d;font-family:monospace;color:#ffd900;padding:8px 30%}h1,h2,h3,h4,h5,h6{font-size:100%}a{color:#ffd900}ul,ol{list-style:none}@keyframes flicker{0%{opacity:.51913684}5%{opacity:.52472367}10%{opacity:.67692741}15%{opacity:.92287791}20%{opacity:.09605824}25%{opacity:.43181387}30%{opacity:.77819172}35%{opacity:.27576365}40%{opacity:.79146835}45%{opacity:.69532422}50%{opacity:.90713251}55%{opacity:.59014101}60%{opacity:.9702681}65%{opacity:.09988339}70%{opacity:.36959547}75%{opacity:.10130684}80%{opacity:.44921993}85%{opacity:.72600288}90%{opacity:.31521938}95%{opacity:.55784539}100%{opacity:.62911118}}body{background:#221d1d;position:relative;overflow:hidden}body::after{content:" ";display:block;position:absolute;top:0;left:0;bottom:0;right:0;background:rgba(34,29,29,.08);opacity:0;z-index:2;pointer-events:none;animation:flicker .04s infinite}body::before{content:" ";display:block;position:absolute;top:0;left:0;bottom:0;right:0;background:linear-gradient(rgba(34,29,29,0) 50%,rgba(6,6,6,0.25) 50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06));z-index:2;background-size:100% 2px,3px 100%;pointer-events:none}