body,html{margin:0;padding:0;height:100%}*{box-sizing:border-box}body{background-color:#221d1d;font-family:monospace;color:#ffd900;padding:8px 30%}h1,h2,h3,h4,h5,h6{font-size:100%}a{color:#ffd900}ul,ol{list-style:none}@keyframes flicker{0%{opacity:.74503334}5%{opacity:.10672331}10%{opacity:.43200997}15%{opacity:.86965258}20%{opacity:.80667808}25%{opacity:.81447754}30%{opacity:.99236068}35%{opacity:.90525525}40%{opacity:.74345086}45%{opacity:.2645394}50%{opacity:.98169748}55%{opacity:.44500384}60%{opacity:.34890601}65%{opacity:.74352735}70%{opacity:.14598697}75%{opacity:.97124844}80%{opacity:.35881682}85%{opacity:.17537248}90%{opacity:.34665217}95%{opacity:.98218386}100%{opacity:.399853}}body{background:#221d1d;position:relative;overflow:hidden}body::after{content:" ";display:block;position:absolute;top:0;left:0;bottom:0;right:0;background:rgba(34,29,29,.08);opacity:0;z-index:2;pointer-events:none}body::before{content:" ";display:block;position:absolute;top:0;left:0;bottom:0;right:0;background:linear-gradient(rgba(34,29,29,0) 50%,rgba(6,6,6,0.25) 50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06));z-index:2;background-size:100% 2px,1px 100%;pointer-events:none}